# ─────────────────────────────────────────────────────
# meor.com Pipeline — Environment Variables
# ─────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your real values below
#   3. Never share or commit your .env file (it has passwords)
# ─────────────────────────────────────────────────────

# ── SUPABASE (your free database) ────────────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key-here

# ── ICANN CZDS (free zone file access) ───────────────
# Apply at: czds.icann.org
# Use the same email/password you register with
CZDS_USERNAME=your-email@example.com
CZDS_PASSWORD=your-czds-password

# ── OPTIONAL: WhatsApp alerts (Meor Premium feature) ─
# Get from: Meta for Developers → WhatsApp Business API
META_WHATSAPP_TOKEN=your-whatsapp-api-token
META_PHONE_NUMBER_ID=your-phone-number-id

# ── OPTIONAL: SEO metrics APIs ───────────────────────
# Moz (free tier: 50 rows/month): moz.com/products/mozscape/access
MOZ_ACCESS_ID=your-moz-access-id
MOZ_SECRET_KEY=your-moz-secret-key

# DataForSEO (pay-as-you-go, ~$0.02/request): dataforseo.com
DATAFORSEO_LOGIN=your-login
DATAFORSEO_PASSWORD=your-password
